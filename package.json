{
  "name": "axijs",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "keywords": [
  ],
  "main": "index.js",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@types/node": "latest",
    "dts-bundle-generator": "^9.5.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17"
  },
  "scripts": {
    "test": "vitest",
    "// --- BUILD PACKAGES PROCESS ---": "",
    "build:emitter": "npm run build --workspace=@axijs/emitter",
    "build:ensure": "npm run build --workspace=@axijs/ensure",
    "// --- PUBLISH PACKAGES PROCESS ---": "",
    "publish:emitter": "npm publish --workspace=@axijs/emitter --access public",
    "publish:ensure": "npm publish --workspace=@axijs/ensure --access public",
    "// --- RELEASE PACKAGES PROCESS ---": "",
    "release:emitter": "npm run build:emitter && npm run publish:emitter",
    "release:ensure": "npm run build:ensure && npm run publish:ensure",
    "// --- DOCUMENTATION ---": "",
    "docs:emitter": "npm run docs --workspace=@axijs/emitter",
    "docs:ensure": "npm run docs --workspace=@axijs/ensure"
  }
}
